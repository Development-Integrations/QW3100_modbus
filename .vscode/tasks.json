{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. Compilar ARM",
            "type": "shell",
            "command": "arm-linux-gnueabihf-gcc",
            "args": [
                "./src/main.c",
                "./src/sensor.c",
                "./src/modbus_comm.c",
                "./lib/cJSON.c",
                "-o",
                "sensor_trident_modbus_ARM",
                "-static",
                "-Wall",
                "-Wextra",
                "-I/home/nesas-10/opt/libmodbus-arm/include/modbus",
                "/home/nesas-10/opt/libmodbus-arm/lib/libmodbus.a"
            ]
        },
        {
            "label": "2. Enviar por SCP",
            "type": "shell",
            "command": "scp",
            "args": [
                "-P",
                "2122",
                "sensor_trident_modbus_ARM",
                "root@192.168.188.39:/SD/"
            ],
            "dependsOn": "1. Compilar ARM"
        },
        {
            "label": "3. Ejecutar en Dispositivo",
            "type": "shell",
            "command": "terminator",
            "args": [
                "-M",
                "-x",
                "ssh",
                "-t",
                "-p",
                "2122",
                "root@192.168.188.39",
                "/SD/sensor_trident_modbus_ARM"
            ],
            "dependsOn": "2. Enviar por SCP",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "group": "ejecucion",
                "clear": false
            }
        },
        {
            "label": "Compilar binario Native para Pruebas ",
            "type": "shell",
            "command": "gcc",
            "args": [
                "./test/main_test.c",
                "./lib/cJSON.c",
                "-o",
                "./test/main_test",
                "-g",
                "-O0",
                "-Wall",
                "-Wextra",
                "-I/home/nesas-10/opt/libmodbus-native/include/modbus",
                "/home/nesas-10/opt/libmodbus-native/lib/libmodbus.a"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ]
}