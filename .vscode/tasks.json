{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. Compilar ARM (cross armv7l)",
            "type": "shell",
            "command": "arm-linux-gnueabihf-gcc",
            "args": [
                "./src/main.c",
                "./src/sensor.c",
                "./src/modbus_comm.c",
                "./src/config.c",
                "./src/persist.c",
                "./src/http_sender.c",
                "./src/circuit_breaker.c",
                "./lib/cJSON.c",
                "-o", "sensor_trident_modbus_ARM",
                "-static",
                "-Wall", "-Wextra",
                "-I/home/nesas-10/opt/libmodbus-arm/include/modbus",
                "-I/home/nesas-10/opt/libcurl-arm/include",
                "/home/nesas-10/opt/libmodbus-arm/lib/libmodbus.a",
                "/home/nesas-10/opt/libcurl-arm/lib/libcurl.a"
            ],
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "2. Enviar por SCP",
            "type": "shell",
            "command": "scp",
            "args": [
                "sensor_trident_modbus_ARM",
                "qw3100-device:/SD/"
            ],
            "dependsOn": "1. Compilar ARM (cross armv7l)",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "3. Ejecutar en Dispositivo",
            "type": "shell",
            "command": "ssh",
            "args": [
                "qw3100-device",
                "/SD/sensor_trident_modbus_ARM --interval 5"
            ],
            "dependsOn": "2. Enviar por SCP",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "clear": false
            }
        },
        {
            "label": "Compilar devlinux (pruebas en PC de desarrollo)",
            "type": "shell",
            "command": "gcc",
            "args": [
                "./test/main_test.c",
                "./src/sensor.c",
                "./src/modbus_comm.c",
                "./src/config.c",
                "./src/persist.c",
                "./src/http_sender.c",
                "./lib/cJSON.c",
                "-o", "./test/main_test",
                "-g", "-O0", "-Wall", "-Wextra",
                "-I/home/nesas-10/opt/libmodbus-devlinux/include/modbus",
                "-I/usr/include/x86_64-linux-gnu",
                "/home/nesas-10/opt/libmodbus-devlinux/lib/libmodbus.a",
                "-lcurl"
            ],
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
